# NODE ENVIRONMENT
NODE_ENV=production
PORT=3000

# TELEGRAM
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ACCOUNTING_BOT_TOKEN=your_accounting_bot_token_here
HEAD_ADMIN_BOT_TOKEN=your_head_admin_bot_token_here
MANAGEMENT_BOT_TOKEN=your_management_bot_token_here
MANAGEMENT_BOT_USERNAME=YourManagementBotUsername
WEBHOOK_URL=https://your-railway-app.railway.app

# DATABASE (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eld_bot
DB_USER=postgres
DB_PASSWORD=password

# ELD PROVIDER KEY (get from DriveHOS portal)
PROVIDER_KEY=your_provider_key_here

# LOGGING
LOG_LEVEL=info
